# rfaf Phase 2 summarize config example
# Copy this file to: ~/.rfaf/config.toml
#
# Priority order at runtime:
# 1) CLI flags
# 2) env vars
# 3) ~/.rfaf/config.toml
# 4) built-in defaults

[llm]
# One of: openai, anthropic, google
provider = "openai"

# Model name for the selected provider
model = "gpt-4o-mini"

# Optional: direct key (prefer env vars in real usage)
# api_key = "replace-me"

# Optional: env var name that contains the API key
# Defaults by provider if omitted:
# - openai   -> OPENAI_API_KEY
# - anthropic-> ANTHROPIC_API_KEY
# - google   -> GOOGLE_GENERATIVE_AI_API_KEY
api_key_env = "OPENAI_API_KEY"

[summary]
# One of: short, medium, long
default_preset = "medium"

# Request timeout in milliseconds
timeout_ms = 20000

# Retries for transient failures (429/network/5xx)
max_retries = 1

# Provider examples
#
# OpenAI
# [llm]
# provider = "openai"
# model = "gpt-4o-mini"
# api_key_env = "OPENAI_API_KEY"
#
# Anthropic
# [llm]
# provider = "anthropic"
# model = "claude-3-7-sonnet-latest"
# api_key_env = "ANTHROPIC_API_KEY"
#
# Google
# [llm]
# provider = "google"
# model = "gemini-2.0-flash"
# api_key_env = "GOOGLE_GENERATIVE_AI_API_KEY"
